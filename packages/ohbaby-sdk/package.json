{
  "name": "ohbaby-sdk",
  "version": "0.1.0",
  "description": "Stable DTO and client contracts shared by ohbaby-agent frontends and runtime adapters",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && tsc -b --force",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist coverage"
  }
}
