{
  "name": "ohbaby-sdk",
  "version": "0.1.9",
  "description": "Stable DTO and client contracts shared by ohbaby-agent frontends and runtime adapters",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/**/*.unit.test.d.ts",
    "!dist/**/*.unit.test.d.ts.map",
    "!dist/**/*.contract.test.d.ts",
    "!dist/**/*.contract.test.d.ts.map",
    "!dist/**/*.integration.test.d.ts",
    "!dist/**/*.integration.test.d.ts.map",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rimraf dist && tsup && tsc -b --force",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist coverage"
  }
}
