{
  "name": "ohbaby-agent",
  "version": "0.1.0",
  "description": "Backend runtime and CLI composition layer for ohbaby-agent",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "ohbaby": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/**/*.unit.test.d.ts",
    "!dist/**/*.unit.test.d.ts.map",
    "!dist/**/*.contract.test.d.ts",
    "!dist/**/*.contract.test.d.ts.map",
    "!dist/**/*.integration.test.d.ts",
    "!dist/**/*.integration.test.d.ts.map",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:inspect": "tsx watch --inspect src/index.ts",
    "start": "node dist/bin.js",
    "build": "rimraf dist && tsup && tsc -b --force",
    "typecheck": "tsc -b",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@tavily/core": "^0.6.4",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "exa-js": "^2.0.12",
    "ohbaby-sdk": "workspace:*",
    "ohbaby-tui": "workspace:*",
    "openai": "^4.77.0",
    "yaml": "^2.8.1",
    "zod": "^3.24.1"
  }
}
