{
  "name": "ohbaby-cli",
  "version": "0.1.9",
  "description": "CLI frontend package for ohbaby-agent",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ohbaby": "dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/web/**",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/**/*.unit.test.d.ts",
    "!dist/**/*.unit.test.d.ts.map",
    "!dist/**/*.contract.test.d.ts",
    "!dist/**/*.contract.test.d.ts.map",
    "!dist/**/*.integration.test.d.ts",
    "!dist/**/*.integration.test.d.ts.map",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "pnpm -r --filter \"ohbaby-cli^...\" --sort build && rimraf dist && tsup && tsc -b --force && pnpm --filter ohbaby-web build && node scripts/copy-web-assets.mjs",
    "start": "node dist/bin.js",
    "typecheck": "tsc -b",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "figlet": "^1.11.0",
    "ink": "6.6.0",
    "ink-gradient": "4.0.1",
    "ohbaby-agent": "workspace:*",
    "ohbaby-server": "workspace:*",
    "ohbaby-sdk": "workspace:*",
    "react": "19.2.3",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/yargs": "^17.0.33"
  }
}
