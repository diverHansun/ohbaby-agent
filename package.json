{
  "name": "ohbaby-agent-workspace",
  "version": "0.1.0",
  "description": "Workspace for ohbaby-agent, ohbaby-sdk, and ohbaby-cli",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter ohbaby-agent dev",
    "dev:inspect": "pnpm --filter ohbaby-agent dev:inspect",
    "start": "pnpm --filter ohbaby-agent start",
    "build": "pnpm -r --filter \"./packages/**\" --sort build",
    "build:check": "pnpm run typecheck",
    "test": "vitest run --passWithNoTests",
    "test:unit": "node scripts/run-vitest-by-type.mjs unit",
    "test:contract": "node scripts/run-vitest-by-type.mjs contract",
    "test:integration": "node scripts/run-vitest-by-type.mjs integration",
    "test:smoke": "node scripts/run-vitest-by-type.mjs smoke",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc -b",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"packages/*/src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,md}\" \"*.{json,js,ts,md,yaml}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json,md}\" \"*.{json,js,ts,md,yaml}\"",
    "preflight": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "clean": "pnpm -r --filter \"./packages/**\" --if-present clean && rimraf coverage dist",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "coding-assistant",
    "cli",
    "llm",
    "typescript",
    "openai",
    "gemini",
    "agent"
  ],
  "author": "ohbaby-agent contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/diverHansun/ohbaby-agent.git"
  },
  "bugs": {
    "url": "https://github.com/diverHansun/ohbaby-agent/issues"
  },
  "homepage": "https://github.com/diverHansun/ohbaby-agent#readme",
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/react": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
