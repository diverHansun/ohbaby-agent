{
  "name": "ohbaby-agent",
  "version": "0.1.0",
  "description": "An AI assistant designed by myself like raising a baby, interacting with him through CLI",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "ohbaby": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:inspect": "tsx watch --inspect src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup",
    "build:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "preflight": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "clean": "rimraf dist coverage",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "coding-assistant",
    "cli",
    "llm",
    "typescript",
    "openai",
    "gemini",
    "agent"
  ],
  "author": "ohbaby-agent contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/diverHansun/ohbaby-agent.git"
  },
  "bugs": {
    "url": "https://github.com/diverHansun/ohbaby-agent/issues"
  },
  "homepage": "https://github.com/diverHansun/ohbaby-agent#readme",
  "dependencies": {
    "@tavily/core": "^0.6.4",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "exa-js": "^2.0.12",
    "ink": "^6.0.0",
    "openai": "^4.77.0",
    "react": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
