{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "ohbaby-sdk": ["packages/ohbaby-sdk/src/index.ts"],
      "ohbaby-agent": ["packages/ohbaby-agent/src/index.ts"],
      "ohbaby-tui": ["packages/ohbaby-tui/src/index.tsx"]
    },
    "types": ["node", "vitest/globals"],
    "jsx": "react-jsx",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "incremental": true
  }
}

